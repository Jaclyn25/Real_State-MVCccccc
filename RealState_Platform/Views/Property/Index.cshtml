@model PropertyListViewModel

@{
    ViewData["Title"] = "Browse properties";
    var placeholderImg = "https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=800&q=80";
}

<div class="property-page">
    <section class="property-page-hero">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active text-white-50" aria-current="page">Properties</li>
                </ol>
            </nav>
            <h1 class="mb-1">Find a home that fits you</h1>
            <p class="text-white-50 mb-0 small">Search by keyword or city. Updated listings from verified agents.</p>
        </div>
    </section>

    <div class="container pb-5">
        <div class="card property-filter-card">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-5 col-lg-5">
                        <label class="form-label small fw-semibold text-muted mb-1">Keyword</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start"><i class="bi bi-search text-muted"></i></span>
                            <input name="search" value="@Model.Search" class="form-control border-start-0 rounded-end" placeholder="Title or keyword…" />
                        </div>
                    </div>
                    <div class="col-md-4 col-lg-4">
                        <label class="form-label small fw-semibold text-muted mb-1">City</label>
                        <input name="city" value="@Model.City" class="form-control" placeholder="e.g. Miami" />
                    </div>
                    <div class="col-md-3 col-lg-3 d-grid">
                        <button type="submit" class="btn btn-search py-2">
                            <i class="bi bi-funnel me-1"></i> Apply filters
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @if (Model?.Properties != null && Model.Properties.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var item in Model.Properties)
                {
                    var img = item.Images != null && item.Images.Any()
                        ? item.Images.First().ImageUrl
                        : placeholderImg;
                    var isRent = string.Equals(item.ListingType, "Rent", StringComparison.OrdinalIgnoreCase);
                    <div class="col d-flex">
                        <div class="card prop-card w-100">
                            <div class="prop-card-img-wrap">
                                <img src="@img" alt="@item.Title" loading="lazy" />
                                <div class="prop-badge-row">
                                    <span class="badge-pill @(isRent ? "badge-rent" : "badge-sale")">@item.ListingType</span>
                                    @if (item.IsSold)
                                    {
                                        <span class="badge-pill" style="background-color: #dc3545;">
                                            <i class="bi bi-check-circle me-1"></i> SOLD
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.PropertyType))
                                    {
                                        <span class="badge-pill badge-type">@item.PropertyType</span>
                                    }
                                </div>
                            </div>
                            <div class="prop-card-body">
                                <p class="prop-price mb-1">@item.Price.ToString("C0")</p>
                                <h2 class="prop-title mb-2">@item.Title</h2>
                                <p class="prop-meta mb-3">
                                    <i class="bi bi-geo-alt me-1"></i>@item.City
                                    @if (item.Bedrooms > 0 || item.Bathrooms > 0)
                                    {
                                        <span class="ms-2"><i class="bi bi-door-open me-1"></i>@item.Bedrooms bd</span>
                                        <span class="ms-2"><i class="bi bi-droplet me-1"></i>@item.Bathrooms ba</span>
                                    }
                                </p>
                                <div class="mt-auto d-grid">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-details">
                                        View details <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5 d-flex justify-content-center" aria-label="Property pages">
                    <ul class="pagination prop-pagination mb-0 flex-wrap justify-content-center">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-search="@Model.Search"
                                   asp-route-city="@Model.City">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="prop-empty">
                <i class="bi bi-building-slash display-4 text-muted mb-3 d-block"></i>
                <h2 class="h5 fw-bold mb-2">No properties match your search</h2>
                <p class="text-muted small mb-4">Try another keyword or city, or clear filters to see everything.</p>
                <a asp-action="Index" class="btn btn-primary rounded-3 px-4">Clear filters</a>
            </div>
        }
    </div>
</div>
