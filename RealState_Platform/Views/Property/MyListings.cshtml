@model PropertyListViewModel

@{
    ViewData["Title"] = "My Listings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary">My Listings</h2>
    <a asp-action="Create" class="btn btn-success">
        ➕ Add New Property
    </a>
</div>

<!-- Search / Filter -->
<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input name="search" value="@Model.Search" class="form-control" placeholder="Search..." />
    </div>
    <div class="col-md-5">
        <input name="city" value="@Model.City" class="form-control" placeholder="City..." />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Search</button>
    </div>
</form>

@if (Model.Properties != null && Model.Properties.Any())
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model.Properties)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (item.Images != null && item.Images.Any())
                    {
                        <img src="@item.Images.First().ImageUrl" class="card-img-top" style="height:180px; object-fit:cover;" alt="@item.Title" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text mb-1"><strong>Price:</strong> @item.Price.ToString("C")</p>
                        <p class="card-text mb-3"><strong>City:</strong> @item.City</p>

                        <div class="mt-auto d-flex gap-2 flex-wrap">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>

                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Are you sure you want to delete this property?');">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-action="MyListings"
                           asp-route-page="@i"
                           asp-route-search="@Model.Search"
                           asp-route-city="@Model.City">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    <div class="text-center mt-5">
        <p class="mb-3">You have no listings yet.</p>
        <a asp-action="Create" class="btn btn-success">
            ➕ Add Your First Property
        </a>
    </div>
}