@model PropertyListViewModel

@{
    ViewData["Title"] = "My listings";
    var placeholderImg = "https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=800&q=80";
}

<div class="property-page">
    <section class="property-page-hero">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active text-white-50" aria-current="page">My listings</li>
                </ol>
            </nav>
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
                <div>
                    <h1 class="mb-1">My listings</h1>
                    <p class="text-white-50 mb-0 small">Manage properties you&apos;ve published.</p>
                </div>
                <a asp-action="Create" class="btn btn-accent-solid rounded-3 px-4 py-2 shadow-sm">
                    <i class="bi bi-plus-lg me-2"></i>Add property
                </a>
            </div>
        </div>
    </section>

    <div class="container pb-5">
        <div class="card property-filter-card">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label small fw-semibold text-muted mb-1">Keyword</label>
                        <input name="search" value="@Model.Search" class="form-control" placeholder="Search your titles…" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold text-muted mb-1">City</label>
                        <input name="city" value="@Model.City" class="form-control" placeholder="Filter by city" />
                    </div>
                    <div class="col-md-3 d-grid">
                        <button type="submit" class="btn btn-search py-2">Filter</button>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.Properties != null && Model.Properties.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var item in Model.Properties)
                {
                    var img = item.Images != null && item.Images.Any()
                        ? item.Images.First().ImageUrl
                        : placeholderImg;
                    var isRent = string.Equals(item.ListingType, "Rent", StringComparison.OrdinalIgnoreCase);
                    <div class="col d-flex">
                        <div class="card prop-card w-100">
                            <div class="prop-card-img-wrap">
                                <img src="@img" alt="@item.Title" loading="lazy" />
                                <div class="prop-badge-row">
                                    <span class="badge-pill @(item.IsApproved ? "approval-badge-live" : "approval-badge-pending")">
                                        @(item.IsApproved ? "Approved" : "Pending review")
                                    </span>
                                    <span class="badge-pill @(isRent ? "badge-rent" : "badge-sale")">@item.ListingType</span>
                                </div>
                            </div>
                            <div class="prop-card-body">
                                <p class="prop-price mb-1">@item.Price.ToString("C0")</p>
                                <h2 class="prop-title mb-2">@item.Title</h2>
                                <p class="prop-meta mb-3">
                                    <i class="bi bi-geo-alt me-1"></i>@item.City
                                </p>
                                <div class="mt-auto d-flex flex-wrap gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-3 flex-grow-1">
                                        View
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm rounded-3 flex-grow-1">
                                        Edit
                                    </a>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this listing?');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-3" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5 d-flex justify-content-center" aria-label="Listings pages">
                    <ul class="pagination prop-pagination mb-0 flex-wrap justify-content-center">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link"
                                   asp-action="MyListings"
                                   asp-route-page="@i"
                                   asp-route-search="@Model.Search"
                                   asp-route-city="@Model.City">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="prop-empty">
                <i class="bi bi-house-add display-4 text-muted mb-3 d-block"></i>
                <h2 class="h5 fw-bold mb-2">No listings yet</h2>
                <p class="text-muted small mb-4">Create your first property to appear in search and on your profile.</p>
                <a asp-action="Create" class="btn btn-accent-solid rounded-3 px-4">
                    <i class="bi bi-plus-lg me-2"></i>Add your first property
                </a>
            </div>
        }
    </div>
</div>
