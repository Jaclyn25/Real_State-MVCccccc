@{
    ViewData["Title"] = "Comments";
    int propertyId = ViewBag.PropertyId ?? 0;
}

<!-- Debug: Show propertyId -->
<script>
    console.log("_CommentsSection.cshtml - ViewBag.PropertyId on server side:", @propertyId);
</script>

<div class="comments-section mt-5" data-property-id="@propertyId">
    <h4 class="mb-4">💬 Comments</h4>

    <!-- Add Comment Form (if authenticated) -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="card mb-4">
            <div class="card-body">
                <form id="commentForm" method="post" action="@Url.Action("AddComment", "Comment")">
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" id="propertyIdInput" name="propertyId" value="@propertyId" />
                    <input type="hidden" name="parentCommentId" value="" />

                    <div class="form-group mb-3">
                        <textarea class="form-control" id="commentContent" name="content" placeholder="Add your comment..." rows="3" required maxlength="1000"></textarea>
                        <small class="form-text text-muted"><span id="charCount">0</span>/1000 characters</small>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="postAsAnonymous" name="isAnonymous">
                        <label class="form-check-label" for="postAsAnonymous">
                            Post as Anonymous
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-chat-left-text"></i> Post Comment
                    </button>
                    <button type="reset" class="btn btn-secondary btn-sm">Clear</button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle"></i>
            <a href="@Url.Action("Login", "Account")">Sign in</a> to add comments.
        </div>
    }

    <!-- Comments List -->
    <div id="commentsList" class="comments-container">
        <div class="text-center">
            <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Loading comments...</span>
            </div>
        </div>
    </div>

    <!-- Load More Button -->
    <div id="loadMoreContainer" class="text-center mt-3" style="display: none;">
        <button id="loadMoreBtn" class="btn btn-outline-secondary btn-sm">Load More Comments</button>
    </div>
</div>

<!-- Alert Container -->
<div id="commentAlert"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>
    let propertyId;
    let currentPage = 1;
    let commentConnection;

    // Initialize propertyId from either hidden input or data attribute
    function initializePropertyId() {
        const hiddenInput = document.getElementById('propertyIdInput');
        if (hiddenInput) {
            propertyId = parseInt(hiddenInput.value);
            console.log("PropertyId from hidden input:", propertyId);
        }

        if (!propertyId || propertyId <= 0) {
            const section = document.querySelector('.comments-section');
            if (section) {
                propertyId = parseInt(section.getAttribute('data-property-id'));
                console.log("PropertyId from data attribute:", propertyId);
            }
        }

        if (!propertyId || propertyId <= 0) {
            console.error("ERROR: PropertyId is not set! Check ViewBag.PropertyId in Details.cshtml");
        } else {
            console.log("✓ PropertyId initialized:", propertyId);
        }
    }

    // Initialize SignalR Connection
    function initializeSignalR() {
        if (typeof signalR === 'undefined') {
            console.error("SignalR library not loaded");
            return;
        }

        commentConnection = new signalR.HubConnectionBuilder()
            .withUrl("/commentHub")
            .withAutomaticReconnect()
            .build();

        commentConnection.on("NewCommentAdded", (data) => {
            console.log("New comment received:", data);
            loadComments(1); // Reload comments
            showNotification("success", "New comment added!");
        });

        commentConnection.on("CommentDeleted", (data) => {
            console.log("Comment deleted:", data);
            loadComments(1); // Reload comments
            showNotification("info", "Comment deleted");
        });

        commentConnection.on("CommentEdited", (data) => {
            console.log("Comment edited:", data);
            loadComments(1); // Reload comments
            showNotification("info", "Comment edited");
        });

        commentConnection.start()
            .then(() => {
                console.log("SignalR connected");
                // Join the property's comment room
                commentConnection.invoke("JoinPropertyComments", propertyId);
            })
            .catch(err => console.error("SignalR connection error:", err));
    }

    // Load Comments
    async function loadComments(page = 1) {
        try {
            const url = `@Url.Action("GetComments", "Comment")?propertyId=${propertyId}&page=${page}`;
            console.log("Loading comments from:", url);
            
            const response = await fetch(url);
            const text = await response.text();
            
            console.log("Raw response:", text);
            
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${text}`);
            }

            let data;
            try {
                data = JSON.parse(text);
            } catch (parseError) {
                console.error("Failed to parse JSON:", text);
                throw new Error("Invalid JSON response from server");
            }

            if (data.comments && data.comments.length > 0) {
                renderComments(data.comments);
                currentPage = page;

                // Show load more button if there are more comments
                document.getElementById('loadMoreContainer').style.display = 
                    data.hasNextPage ? 'block' : 'none';
            } else {
                document.getElementById('commentsList').innerHTML = 
                    '<p class="text-muted text-center">No comments yet. Be the first to comment!</p>';
                document.getElementById('loadMoreContainer').style.display = 'none';
            }
        } catch (error) {
            console.error("Error loading comments:", error);
            document.getElementById('commentsList').innerHTML = 
                '<p class="alert alert-danger">Error loading comments: ' + error.message + '</p>';
        }
    }

    // Render Comments
    function renderComments(comments) {
        const container = document.getElementById('commentsList');
        container.innerHTML = '';

        comments.forEach(comment => {
            const commentDiv = document.createElement('div');
            commentDiv.className = 'card mb-3 comment-item';
            commentDiv.id = `comment-${comment.id}`;

            let actions = '';
            if (comment.isOwner) {
                actions = `
                    <div class="comment-actions mt-2">
                        <button class="btn btn-sm btn-link text-danger" onclick="deleteComment(${comment.id})">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                        <button class="btn btn-sm btn-link" onclick="editComment(${comment.id})">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                    </div>
                `;
            }

            commentDiv.innerHTML = `
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="card-subtitle mb-1">
                                <strong>${escapeHtml(comment.userName)}</strong>
                                <small class="text-muted">${comment.userEmail}</small>
                            </h6>
                            <small class="text-muted">${formatDate(comment.createdAt)}</small>
                        </div>
                    </div>
                    <p class="card-text mt-2">${escapeHtml(comment.content)}</p>
                    ${actions}
                </div>
            `;

            container.appendChild(commentDiv);
        });
    }

    // Delete Comment
    async function deleteComment(commentId) {
        if (!confirm("Are you sure you want to delete this comment?")) return;

        try {
            const token = document.querySelector('[name="__RequestVerificationToken"]').value;
            const formData = new FormData();
            formData.append('commentId', commentId);
            formData.append('__RequestVerificationToken', token);

            const response = await fetch('@Url.Action("DeleteComment", "Comment")', {
                method: 'POST',
                body: formData
            });

            const text = await response.text();
            
            if (!response.ok) {
                showNotification("danger", `Error: ${response.status}`);
                return;
            }

            let result;
            try {
                result = JSON.parse(text);
            } catch (e) {
                console.error("JSON parse error:", text);
                showNotification("danger", "Server error");
                return;
            }

            if (result.success) {
                showNotification("success", "Comment deleted successfully");
                loadComments(1);
            } else {
                showNotification("danger", result.message);
            }
        } catch (error) {
            console.error("Error deleting comment:", error);
            showNotification("danger", "Error deleting comment");
        }
    }

    // Edit Comment (basic implementation)
    async function editComment(commentId) {
        const newContent = prompt("Edit your comment:");
        if (!newContent || newContent.trim() === '') return;

        try {
            const token = document.querySelector('[name="__RequestVerificationToken"]').value;
            const formData = new FormData();
            formData.append('commentId', commentId);
            formData.append('newContent', newContent);
            formData.append('__RequestVerificationToken', token);

            const response = await fetch('@Url.Action("EditComment", "Comment")', {
                method: 'POST',
                body: formData
            });

            const text = await response.text();
            
            if (!response.ok) {
                showNotification("danger", `Error: ${response.status}`);
                return;
            }

            let result;
            try {
                result = JSON.parse(text);
            } catch (e) {
                console.error("JSON parse error:", text);
                showNotification("danger", "Server error");
                return;
            }

            if (result.success) {
                showNotification("success", "Comment updated successfully");
                loadComments(1);
            } else {
                showNotification("danger", result.message);
            }
        } catch (error) {
            console.error("Error editing comment:", error);
            showNotification("danger", "Error editing comment");
        }
    }

    // Submit Comment Form
    document.getElementById('commentForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const content = document.getElementById('commentContent').value;
        const isAnonymous = document.getElementById('postAsAnonymous').checked;
        
        console.log("Form data before submit:");
        console.log("- propertyId:", propertyId, "(from JS variable)");
        console.log("- content:", content);
        console.log("- content length:", content.length);
        console.log("- isAnonymous:", isAnonymous);

        if (!content.trim()) {
            showNotification("warning", "Please enter a comment");
            return;
        }

        if (!propertyId || propertyId <= 0) {
            showNotification("danger", "Property ID is missing or invalid (PropertyId=" + propertyId + ")");
            console.error("ERROR: propertyId is invalid:", propertyId);
            return;
        }

        try {
            const token = document.querySelector('[name="__RequestVerificationToken"]')?.value;
            console.log("- token:", token ? "present" : "missing");

            const formData = new FormData();
            formData.append('propertyId', propertyId);
            formData.append('content', content);
            formData.append('isAnonymous', isAnonymous);
            formData.append('__RequestVerificationToken', token);

            // Log form data
            console.log("FormData entries:");
            for (let [key, value] of formData.entries()) {
                console.log(`  ${key}: ${value}`);
            }

            const response = await fetch('@Url.Action("AddComment", "Comment")', {
                method: 'POST',
                body: formData
            });

            const text = await response.text();
            console.log("Response status:", response.status);
            console.log("Response text:", text);

            if (!response.ok) {
                showNotification("danger", `Error: ${response.status} - ${text || 'No response body'}`);
                return;
            }

            let result;
            try {
                result = JSON.parse(text);
            } catch (parseError) {
                console.error("JSON parsing error:", text);
                showNotification("danger", "Server error (invalid response)");
                return;
            }

            if (result.success) {
                showNotification("success", "Comment added successfully!");
                document.getElementById('commentForm').reset();
                document.getElementById('charCount').textContent = '0';
                loadComments(1);
            } else {
                showNotification("danger", result.message || "Error adding comment");
            }
        } catch (error) {
            console.error("Error:", error);
            showNotification("danger", "Error submitting comment: " + error.message);
        }
    });

    // Character Counter
    document.getElementById('commentContent')?.addEventListener('input', function() {
        document.getElementById('charCount').textContent = this.value.length;
    });

    // Load More Comments
    document.getElementById('loadMoreBtn')?.addEventListener('click', () => {
        loadComments(currentPage + 1);
    });

    // Helper Functions
    function formatDate(date) {
        const d = new Date(date);
        return d.toLocaleDateString() + ' ' + d.toLocaleTimeString();
    }

    function escapeHtml(text) {
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, m => map[m]);
    }

    function showNotification(type, message) {
        const alertDiv = document.getElementById('commentAlert');
        alertDiv.innerHTML = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;
        setTimeout(() => alertDiv.innerHTML = '', 5000);
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        initializePropertyId();
        
        if (!propertyId || propertyId <= 0) {
            document.getElementById('commentsList').innerHTML = 
                '<p class="alert alert-danger">Error: Property ID not found. Please refresh the page.</p>';
            return;
        }

        initializeSignalR();
        loadComments(1);
    });
</script>

<style>
    .comments-section {
        background-color: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
    }

    .comment-item {
        border-left: 3px solid #007bff;
        transition: all 0.3s ease;
    }

    .comment-item:hover {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .comment-actions {
        display: flex;
        gap: 10px;
    }

    #commentsList {
        max-height: 600px;
        overflow-y: auto;
    }
</style>
