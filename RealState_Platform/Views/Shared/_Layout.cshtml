<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · RealHome</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 256 256'><rect width='256' height='256' fill='%23f8f9fa'/><rect x='48' y='80' width='160' height='140' fill='%23007bff' rx='8'/><rect x='108' y='140' width='40' height='80' fill='%230d6efd' rx='4'/><circle cx='140' cy='180' r='3' fill='%23ffc107'/><rect x='60' y='95' width='22' height='22' fill='%23fff' rx='2'/><rect x='95' y='95' width='22' height='22' fill='%23fff' rx='2'/><rect x='130' y='95' width='22' height='22' fill='%23fff' rx='2'/><rect x='165' y='95' width='22' height='22' fill='%23fff' rx='2'/><polygon points='40,80 128,30 216,80' fill='%230d6efd' opacity='0.9'/></svg>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/property.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    
</head>
<body>
    <div class="app-shell">
        <header>
            <nav class="navbar navbar-expand-lg site-navbar sticky-top">
                <div class="container">
                    <a class="navbar-brand py-0" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="brand-mark"><i class="bi bi-buildings-fill"></i></span>
                        <span class="brand-text">
                            RealHome
                            <small>Find your place</small>
                        </span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav mx-lg-4 my-2 my-lg-0 align-items-lg-center gap-lg-1">
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                                   asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door d-lg-none me-2"></i>Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Property" asp-action="Index">
                                    <i class="bi bi-grid-1x2 d-lg-none me-2"></i>Properties
                                </a>
                            </li>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (User.IsInRole("Agent"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-controller="Property" asp-action="MyListings">
                                            <i class="bi bi-card-list d-lg-none me-2"></i>My Listings
                                        </a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Favorite" asp-action="MyFavorites">
                                        <i class="bi bi-heart d-lg-none me-2"></i>Favorites
                                    </a>
                                </li>
                                @if (User.IsInRole("Customer"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-controller="Property" asp-action="MyPurchases">
                                            <i class="bi bi-bag-check d-lg-none me-2"></i>My Purchases
                                        </a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Inquiry" asp-action="Inbox">
                                        <i class="bi bi-inbox d-lg-none me-2"></i>Inbox
                                    </a>
                                </li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle nav-user" href="javascript:void(0);" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-shield-check me-1"></i> Admin
                                        </a>
                                        <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2 text-muted"></i>Dashboard</a></li>
                                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageUsers"><i class="bi bi-people me-2 text-muted"></i>Manage Users</a></li>
                                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="ApproveListings"><i class="bi bi-check2-circle me-2 text-muted"></i>Approve Listings</a></li>
                                        </ul>
                                    </li>
                                }
                            }
                        </ul>
                        <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <span class="nav-link text-white-50">
                                        @User.Identity?.Name
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill ms-2">
                                            <i class="bi bi-box-arrow-right me-1"></i>Log out
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="btn btn-nav-outline rounded-pill" asp-controller="Account" asp-action="Login">Log in</a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-nav-solid rounded-pill" asp-controller="Account" asp-action="Register">Sign up</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="app-main">
            @RenderBody()
        </main>

        <footer class="site-footer pt-5 pb-3">
            <div class="container">
                <div class="row g-4 g-lg-5">
                    <div class="col-md-6 col-lg-4">
                        <div class="footer-brand mb-3">
                            <span class="brand-mark" style="width:36px;height:36px;font-size:1rem;"><i class="bi bi-buildings-fill"></i></span>
                            RealHome
                        </div>
                        <p class="small mb-0 pe-lg-3" style="line-height:1.65;">
                            Search verified listings, save favorites, and connect with agents—all in one place built for buyers, renters, and professionals.
                        </p>
                    </div>
                    <div class="col-6 col-md-3 col-lg-2 offset-lg-1">
                        <p class="footer-heading">Explore</p>
                        <ul class="list-unstyled footer-links small mb-0">
                            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a asp-controller="Property" asp-action="Index">Properties</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Create account</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-md-3 col-lg-2">
                        <p class="footer-heading">Company</p>
                        <ul class="list-unstyled footer-links small mb-0">
                            <li><a asp-controller="Home" asp-action="Privacy">Privacy policy</a></li>
                            <li><a href="#">Terms</a></li>
                            <li><a href="#">Contact</a></li>
                        </ul>
                    </div>
                    <div class="col-md-12 col-lg-3">
                        <p class="footer-heading">Stay in touch</p>
                        <p class="small mb-2">hello@realhome.example</p>
                        <p class="small mb-3">Mon–Fri, 9:00–18:00</p>
                        <div class="social">
                            <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                        </div>
                    </div>
                </div>
                <div class="footer-bottom d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
                    <span>&copy; @DateTime.Now.Year RealHome. All rights reserved.</span>
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/shopping-cart.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
