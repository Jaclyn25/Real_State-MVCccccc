@model MyFavoritesViewModel

@{
    ViewData["Title"] = "My Favorites";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">
        <i class="bi bi-heart-fill"></i> My Favorite Properties
        <span class="badge bg-info ms-2">@Model.TotalFavorites</span>
    </h2>

    @if (Model?.Favorites != null && Model.Favorites.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var favorite in Model.Favorites)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm favorite-card" data-favorite-id="@favorite.FavoriteId">
                        <div class="position-relative">
                            <img src="@favorite.ImageUrl" class="card-img-top" 
                                 style="height: 200px; object-fit: cover;" 
                                 alt="@favorite.Title" />
                            <button class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2 remove-favorite-btn"
                                    data-favorite-id="@favorite.FavoriteId"
                                    title="Remove from favorites">
                                <i class="bi bi-heart-fill"></i> Remove
                            </button>
                            <span class="badge bg-primary position-absolute bottom-0 start-0 m-2">
                                @favorite.ListingType
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <a asp-controller="Property" asp-action="Details" asp-route-id="@favorite.PropertyId"
                                   class="text-decoration-none text-dark">
                                    @favorite.Title
                                </a>
                            </h5>

                            <p class="card-text mb-2">
                                <strong class="text-success fs-5">$@favorite.Price.ToString("N2")</strong>
                            </p>

                            <div class="row text-muted small mb-3">
                                <div class="col-6">
                                    @if (favorite.Bedrooms.HasValue)
                                    {
                                        <span><i class="bi bi-door-closed"></i> @favorite.Bedrooms Beds</span>
                                    }
                                </div>
                                <div class="col-6">
                                    @if (favorite.Bathrooms.HasValue)
                                    {
                                        <span><i class="bi bi-droplet"></i> @favorite.Bathrooms Baths</span>
                                    }
                                </div>
                            </div>

                            <p class="card-text small text-muted mb-2">
                                <i class="bi bi-geo-alt"></i> @favorite.City, @favorite.Address
                            </p>

                            @if (favorite.Area.HasValue)
                            {
                                <p class="card-text small text-muted mb-3">
                                    <i class="bi bi-ruler"></i> @favorite.Area m²
                                </p>
                            }

                            <div class="mt-auto d-flex gap-2">
                                <a asp-controller="Property" asp-action="Details" asp-route-id="@favorite.PropertyId"
                                   class="btn btn-sm btn-primary flex-grow-1">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                                <a href="@Url.Action("SendInquiry", "Inquiry")?propertyId=@favorite.PropertyId"
                                   class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="bi bi-envelope"></i> Inquire
                                </a>
                            </div>

                            <small class="text-muted mt-2">
                                Added: @favorite.AddedAt.ToString("MMM dd, yyyy")
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (Model.PageNumber > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="MyFavorites" asp-route-page="1">First</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="MyFavorites" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
                        </li>
                    }

                    @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                    {
                        @if (i == Model.PageNumber)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="MyFavorites" asp-route-page="@i">@i</a>
                            </li>
                        }
                    }

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="MyFavorites" asp-route-page="@(Model.PageNumber + 1)">Next</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="MyFavorites" asp-route-page="@Model.TotalPages">Last</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h5><i class="bi bi-heart"></i> No favorites yet</h5>
            <p>Start adding properties to your favorites to keep track of your favorite listings.</p>
            <a asp-controller="Property" asp-action="Index" class="btn btn-primary mt-3">
                <i class="bi bi-search"></i> Browse Properties
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.remove-favorite-btn').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                
                if (!confirm('Remove from favorites?')) return;
                
                const favoriteId = this.dataset.favoriteId;
                const token = document.querySelector('[name="__RequestVerificationToken"]')?.value;
                
                try {
                    const formData = new FormData();
                    formData.append('favoriteId', favoriteId);
                    formData.append('__RequestVerificationToken', token);

                    const response = await fetch('@Url.Action("RemoveFromFavorite", "Favorite")', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error('HTTP Error: ' + response.status);
                    }

                    const text = await response.text();
                    const result = JSON.parse(text);
                    
                    if (result.success) {
                        // Animate card removal
                        const card = document.querySelector(`[data-favorite-id="${favoriteId}"]`);
                        card.style.opacity = '0.5';
                        setTimeout(() => {
                            card.closest('.col').remove();
                            
                            // Reload if no favorites left
                            const remainingCards = document.querySelectorAll('.favorite-card').length;
                            if (remainingCards === 0) {
                                location.reload();
                            }
                        }, 300);
                    } else {
                        alert('Error: ' + result.message);
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to remove from favorites: ' + error.message);
                }
            });
        });
    </script>
}
