@using RealState_Platform.Controllers
@model InboxViewModel

@{
    ViewData["Title"] = "Inquiries Inbox";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">
        <i class="bi bi-inbox"></i> Inquiries Inbox
        <span class="badge bg-info ms-2">@Model.TotalInquiries</span>
    </h2>

    @if (Model?.Inquiries != null && Model.Inquiries.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-light">
                    <tr>
                        <th>From</th>
                        <th>Property</th>
                        <th>Message</th>
                        <th>Contact</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inquiry in Model.Inquiries)
                    {
                        <tr>
                            <td>
                                <strong>@inquiry.CustomerName</strong><br>
                                <small class="text-muted">@inquiry.CustomerEmail</small>
                            </td>
                            <td>
                                <a asp-controller="Property" asp-action="Details" asp-route-id="@inquiry.PropertyId" 
                                   class="text-decoration-none">
                                    @inquiry.PropertyTitle
                                </a>
                            </td>
                            <td>
                                <small>@(inquiry.Message.Length > 50 ? inquiry.Message.Substring(0, 50) + "..." : inquiry.Message)</small>
                            </td>
                            <td>
                                <a href="tel:@inquiry.CustomerPhone" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-telephone"></i> @inquiry.CustomerPhone
                                </a><br>
                                <a href="mailto:@inquiry.CustomerEmail" class="btn btn-sm btn-outline-secondary mt-1">
                                    <i class="bi bi-envelope"></i> Email
                                </a>
                            </td>
                            <td>
                                @if (inquiry.Status == "New")
                                {
                                    <span class="badge bg-warning text-dark">@inquiry.Status</span>
                                }
                                else if (inquiry.Status == "Read")
                                {
                                    <span class="badge bg-info">@inquiry.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@inquiry.Status</span>
                                }
                            </td>
                            <td>
                                <small>
                                    @inquiry.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                </small>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-info mark-read-btn" 
                                        data-inquiry-id="@inquiry.Id"
                                    @if (inquiry.Status != "New") { <text>disabled</text> }>
                                    <i class="bi bi-check-circle"></i> Mark Read
                                </button>
                                <a href="@Url.Action("Details", "Property", new { id = inquiry.PropertyId })" 
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (Model.PageNumber > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Inbox" asp-route-page="1">First</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Inbox" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
                        </li>
                    }

                    @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                    {
                        @if (i == Model.PageNumber)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Inbox" asp-route-page="@i">@i</a>
                            </li>
                        }
                    }

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Inbox" asp-route-page="@(Model.PageNumber + 1)">Next</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Inbox" asp-route-page="@Model.TotalPages">Last</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h5>No inquiries yet</h5>
            <p>When customers send inquiries about your properties, they will appear here.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.mark-read-btn').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                const inquiryId = this.dataset.inquiryId;
                const token = document.querySelector('[name="__RequestVerificationToken"]')?.value;
                
                try {
                    const formData = new FormData();
                    formData.append('id', inquiryId);
                    formData.append('__RequestVerificationToken', token);

                    const response = await fetch('@Url.Action("MarkAsRead", "Inquiry")', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error('HTTP Error: ' + response.status);
                    }

                    const text = await response.text();
                    const result = JSON.parse(text);
                    
                    if (result.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + result.message);
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to mark as read: ' + error.message);
                }
            });
        });
    </script>
}
