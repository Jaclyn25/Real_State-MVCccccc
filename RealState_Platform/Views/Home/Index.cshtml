@{
    ViewData["Title"] = "Find Your Dream Home";
}

<div class="home-landing">
    <!-- Hero -->
    <section class="hero-section text-center text-md-start">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-9 col-xl-8 mx-auto text-center">
                    <p class="text-white-50 small text-uppercase fw-semibold letter-spacing mb-2">Premium listings · Trusted agents</p>
                    <h1 class="display-4 fw-bold mb-3">Find Your Perfect Place to Call Home</h1>
                    <p class="lead mb-4 text-white-50 mx-auto" style="max-width: 36rem;">
                        Discover apartments, houses, and commercial spaces tailored to your lifestyle—with search and saved favorites built in.
                    </p>

                    <div class="search-box p-4 rounded-4">
                        <form asp-controller="Property" asp-action="Index" method="get" class="row g-3 justify-content-center align-items-stretch align-items-md-end">
                            <div class="col-md-5">
                                <label class="form-label text-white-50 small mb-1 d-none d-md-block">Keyword</label>
                                <input type="text" name="search" class="form-control form-control-lg rounded-3 border-0 shadow-sm" placeholder="Search by title or keyword…" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white-50 small mb-1 d-none d-md-block">City</label>
                                <select name="city" class="form-select form-select-lg rounded-3 border-0 shadow-sm">
                                    <option value="">All cities</option>
                                    <option value="New York">New York</option>
                                    <option value="Los Angeles">Los Angeles</option>
                                    <option value="Chicago">Chicago</option>
                                    <option value="Miami">Miami</option>
                                </select>
                            </div>
                            <div class="col-md-3 d-grid">
                                <button type="submit" class="btn btn-lg rounded-3 btn-hero-search">
                                    <i class="bi bi-search me-2"></i>Search
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="stats-row py-3">
        <div class="container">
            <div class="row text-center g-0">
                <div class="col-6 col-md-3 stat-item">
                    <strong>10k+</strong>
                    <span>Listings</span>
                </div>
                <div class="col-6 col-md-3 stat-item">
                    <strong>120+</strong>
                    <span>Cities</span>
                </div>
                <div class="col-6 col-md-3 stat-item">
                    <strong>500+</strong>
                    <span>Agents</span>
                </div>
                <div class="col-6 col-md-3 stat-item">
                    <strong>24/7</strong>
                    <span>Support</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="py-5 bg-white border-bottom">
        <div class="container py-lg-2">
            <div class="text-center mb-5">
                <h2 class="section-title h1 mb-2">Why RealHome</h2>
                <p class="text-muted mb-0">Everything you need to search smarter and move faster.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-tile p-4 h-100 bg-light">
                        <div class="feature-icon mb-3"><i class="bi bi-house-heart"></i></div>
                        <h3 class="h5 fw-bold mb-2">Wide range of properties</h3>
                        <p class="text-muted small mb-0">From compact apartments to luxury estates—filter by location, price, and type.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-tile p-4 h-100 bg-light">
                        <div class="feature-icon mb-3"><i class="bi bi-shield-check"></i></div>
                        <h3 class="h5 fw-bold mb-2">Trusted agents</h3>
                        <p class="text-muted small mb-0">Listings from verified professionals—message through inquiries and stay in the loop.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-tile p-4 h-100 bg-light">
                        <div class="feature-icon mb-3"><i class="bi bi-geo-alt"></i></div>
                        <h3 class="h5 fw-bold mb-2">Prime locations</h3>
                        <p class="text-muted small mb-0">Explore neighborhoods with the amenities that matter to you and your family.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories -->
    <section class="py-5 bg-light">
        <div class="container py-lg-2">
            <div class="text-center mb-5">
                <h2 class="section-title h1 mb-2">Explore by category</h2>
                <p class="text-muted mb-0">Jump into the type of property you need.</p>
            </div>
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <a asp-controller="Property" asp-action="Index" asp-route-search="Villa" class="text-decoration-none">
                        <div class="card category-card shadow-sm">
                            <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Luxury villas" />
                            <div class="category-overlay">
                                <h3 class="h4 m-0 fw-bold">Luxury villas</h3>
                                <small class="text-white-50">Spacious &amp; private</small>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <a asp-controller="Property" asp-action="Index" asp-route-search="Apartment" class="text-decoration-none">
                        <div class="card category-card shadow-sm">
                            <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Modern apartments" />
                            <div class="category-overlay">
                                <h3 class="h4 m-0 fw-bold">Modern apartments</h3>
                                <small class="text-white-50">Heart of the city</small>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-12">
                    <a asp-controller="Property" asp-action="Index" asp-route-search="Commercial" class="text-decoration-none">
                        <div class="card category-card shadow-sm">
                            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Commercial spaces" />
                            <div class="category-overlay">
                                <h3 class="h4 m-0 fw-bold">Commercial spaces</h3>
                                <small class="text-white-50">Grow your business</small>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-strip py-5">
        <div class="container text-center py-lg-2 position-relative">
            <h2 class="section-title display-6 text-white mb-3">Are you a real estate agent?</h2>
            <p class="lead text-white-50 mb-4 mx-auto" style="max-width: 32rem;">
                List properties, manage inquiries, and reach buyers and renters on one platform.
            </p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-lg rounded-pill px-5 py-3 btn-cta shadow">
                Sign up as an agent <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    </section>
</div>
