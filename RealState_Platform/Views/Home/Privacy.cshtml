@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="content-hero">
    <div class="container text-center py-2">
        <h1 class="display-6 fw-bold mb-2">@ViewData["Title"]</h1>
        <p class="text-white-50 mb-0 lead small">How we collect, use, and protect your information.</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <h2 class="h5 fw-bold mb-3">1. Introduction</h2>
                    <p class="text-muted small lh-lg mb-4">
                        Welcome to RealHome. We are committed to protecting your privacy. This policy explains how we collect, use, and safeguard your information when you use our website. If you do not agree with these terms, please do not use the site.
                    </p>

                    <h2 class="h5 fw-bold mb-3">2. Information we collect</h2>
                    <p class="text-muted small lh-lg mb-2">We may collect information in the following ways:</p>
                    <ul class="text-muted small lh-lg mb-4">
                        <li><strong class="text-dark">Personal data:</strong> Name, email, phone, and other details you provide when you register or use features such as inquiries and favorites.</li>
                        <li><strong class="text-dark">Technical data:</strong> IP address, browser type, and pages visited to improve performance and security.</li>
                    </ul>

                    <h2 class="h5 fw-bold mb-3">3. How we use your information</h2>
                    <p class="text-muted small lh-lg mb-2">We may use your information to:</p>
                    <ul class="text-muted small lh-lg mb-4">
                        <li>Create and manage your account.</li>
                        <li>Send account-related messages and respond to inquiries.</li>
                        <li>Enable communication between users (e.g. buyers and agents).</li>
                        <li>Improve and secure our platform.</li>
                    </ul>

                    <h2 class="h5 fw-bold mb-3">4. Contact us</h2>
                    <p class="text-muted small lh-lg mb-0">
                        Questions about this policy? Contact us at
                        <a href="mailto:privacy@realhome.example">privacy@realhome.example</a>.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
