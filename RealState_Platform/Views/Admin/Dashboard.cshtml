@model DashboardVM

@{
    ViewData["Title"] = "Admin dashboard";
    var approvedCount = Model.TotalProperties - Model.PendingProperties;
}

<div class="admin-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <div class="row g-4 admin-shell">
            <div class="col-lg-3 col-xl-2">
                @await Html.PartialAsync("_AdminNav")
            </div>
            <div class="col-lg-9 col-xl-10 admin-content">
                <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
                    <div>
                        <h1 class="admin-page-title h2 mb-1">Dashboard</h1>
                        <p class="text-muted small mb-0">Overview of properties, users, and inquiries.</p>
                    </div>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-3">
                        <i class="bi bi-house me-1"></i> Site home
                    </a>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6 col-xl-3">
                        <div class="card admin-stat-card stat-navy">
                            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                                <div>
                                    <div class="stat-label">Total properties</div>
                                    <div class="stat-value">@Model.TotalProperties</div>
                                </div>
                                <div class="stat-icon"><i class="bi bi-buildings"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="card admin-stat-card stat-warn">
                            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                                <div>
                                    <div class="stat-label">Pending approval</div>
                                    <div class="stat-value">@Model.PendingProperties</div>
                                </div>
                                <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="card admin-stat-card stat-ok">
                            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                                <div>
                                    <div class="stat-label">Users</div>
                                    <div class="stat-value">@Model.TotalUsers</div>
                                </div>
                                <div class="stat-icon"><i class="bi bi-people"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="card admin-stat-card stat-teal">
                            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                                <div>
                                    <div class="stat-label">Inquiries</div>
                                    <div class="stat-value">@Model.TotalInquiries</div>
                                </div>
                                <div class="stat-icon"><i class="bi bi-inbox"></i></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="card admin-panel h-100">
                            <div class="card-header">Listing approval status</div>
                            <div class="card-body">
                                <canvas id="propertyChart" height="220"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="card admin-panel h-100">
                            <div class="card-header">Users &amp; inquiries</div>
                            <div class="card-body">
                                <canvas id="userInquiryChart" height="220"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 d-flex flex-wrap gap-2">
                    <a asp-action="ApproveListings" class="btn btn-primary rounded-3"><i class="bi bi-patch-check me-2"></i>Review pending</a>
                    <a asp-action="ManageUsers" class="btn btn-outline-primary rounded-3"><i class="bi bi-people me-2"></i>Manage users</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const navy = '#1a4b8c';
        const gold = '#c9a84c';
        const slate = '#64748b';

        new Chart(document.getElementById('propertyChart'), {
            type: 'doughnut',
            data: {
                labels: ['Approved / live', 'Pending review'],
                datasets: [{
                    data: [@approvedCount, @Model.PendingProperties],
                    backgroundColor: [navy, gold],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });

        new Chart(document.getElementById('userInquiryChart'), {
            type: 'bar',
            data: {
                labels: ['Users', 'Inquiries'],
                datasets: [{
                    label: 'Count',
                    data: [@Model.TotalUsers, @Model.TotalInquiries],
                    backgroundColor: [navy, '#0e7490'],
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                plugins: { legend: { display: false } }
            }
        });
    </script>
}
