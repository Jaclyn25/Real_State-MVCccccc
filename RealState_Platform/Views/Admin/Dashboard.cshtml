@model RealState_Platform.ViewModel.DashboardVM

@* Include Bootstrap & FontAwesome (if not already in _Layout.cshtml) *@
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="d-flex">
    <!-- Sidebar -->
    <nav class="bg-dark text-white vh-100 p-3" style="width: 250px;">
        <h3 class="text-center mb-4"><i class="fas fa-building"></i> RealEstate</h3>
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" asp-controller="Admin" asp-action="ManageUsers"><i class="fas fa-users me-2"></i> Users</a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" asp-controller="Admin" asp-action="ApproveListings"><i class="fas fa-check-circle me-2"></i> Approve Listings</a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" asp-controller="Property" asp-action="Index"><i class="fas fa-home me-2"></i> Properties</a>
            </li>
            <li class="nav-item mb-2">
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Inquiries"><i class="fas fa-envelope me-2"></i> Inquiries</a>
            </li>
        </ul>
    </nav>

    <!-- Main content -->
    <div class="flex-grow-1 p-4">
        <h2 class="mb-4">Admin Dashboard</h2>

        <!-- Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-primary shadow-sm">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <h6>Total Properties</h6>
                            <h3>@Model.TotalProperties</h3>
                        </div>
                        <i class="fas fa-building fa-2x"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-dark bg-warning shadow-sm">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <h6>Pending</h6>
                            <h3>@Model.PendingProperties</h3>
                        </div>
                        <i class="fas fa-hourglass-half fa-2x"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success shadow-sm">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <h6>Users</h6>
                            <h3>@Model.TotalUsers</h3>
                        </div>
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info shadow-sm">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <h6>Inquiries</h6>
                            <h3>@Model.TotalInquiries</h3>
                        </div>
                        <i class="fas fa-envelope fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header">
                        Properties Status
                    </div>
                    <div class="card-body">
                        <canvas id="propertyChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header">
                        Users & Inquiries
                    </div>
                    <div class="card-body">
                        <canvas id="userInquiryChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Example data for charts (replace with real data from ViewModel if needed)
    const propertyCtx = document.getElementById('propertyChart').getContext('2d');
    new Chart(propertyCtx, {
        type: 'doughnut',
        data: {
            labels: ['Approved', 'Pending', 'Sold/Rented'],
            datasets: [{
                data: [@Model.TotalProperties - @Model.PendingProperties, @Model.PendingProperties, 0],
                backgroundColor: ['#0d6efd', '#ffc107', '#198754']
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'bottom' } }
        }
    });

    const userInquiryCtx = document.getElementById('userInquiryChart').getContext('2d');
    new Chart(userInquiryCtx, {
        type: 'bar',
        data: {
            labels: ['Users', 'Inquiries'],
            datasets: [{
                label: 'Count',
                data: [@Model.TotalUsers, @Model.TotalInquiries],
                backgroundColor: ['#198754', '#0dcaf0']
            }]
        },
        options: { responsive: true }
    });
</script>