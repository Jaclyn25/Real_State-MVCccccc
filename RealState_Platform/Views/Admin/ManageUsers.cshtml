@model List<UserWithRoleViewModel>

<h2>Manage Users</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Change Role</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Name</td>
                <td>@user.Email</td>
                <td>@(user.IsActive ? "Active" : "Blocked")</td>

                <!-- Change Role -->
                <td>
                    <form asp-action="UpdateRole" method="post">
                        <input type="hidden" name="userId" value="@user.UserId" />

                        <select name="newRole" class="form-select">
                            <option value="Admin" selected="@(user.CurrentRole == "Admin")">Admin</option>
                            <option value="Agent" selected="@(user.CurrentRole == "Agent")">Agent</option>
                            <option value="Customer" selected="@(user.CurrentRole == "Customer")">Customer</option>
                        </select>

                        <button type="submit" class="btn btn-primary btn-sm mt-1">
                            Update
                        </button>
                    </form>
                </td>

                <!-- Block / Unblock -->
                <td>
                    <form asp-action="ToggleUserStatus" method="post">
                        <input type="hidden" name="userId" value="@user.UserId" />

                        <button class="btn btn-warning btn-sm">
                            @(user.IsActive ? "Block" : "Unblock")
                        </button>
                    </form>
                </td>

            </tr>
        }
    </tbody>
</table>