@model RealState_Platform.ViewModel.LoginViewModel

@{
    ViewData["Title"] = "Log In";
}

<div class="auth-page">
    <div class="container">
        <div class="row g-0 justify-content-center shadow-lg rounded-4 overflow-hidden auth-card" style="max-width: 960px; margin-left: auto; margin-right: auto;">
            <div class="col-lg-5 d-none d-lg-flex auth-visual">
                <div class="auth-visual-inner mt-auto">
                    <h2>Welcome back</h2>
                    <p class="text-white-50 mb-0 small">
                        Sign in to manage favorites, inquiries, and listings in one dashboard.
                    </p>
                </div>
            </div>
            <div class="col-lg-7 bg-white">
                <div class="p-4 p-md-5">
                    <div class="text-center text-lg-start mb-4">
                        <div class="auth-icon-wrap mb-3"><i class="bi bi-box-arrow-in-right"></i></div>
                        <h1 class="h3 fw-bold mb-1 font-heading">Log in</h1>
                        <p class="text-muted mb-0 small">Use your email and password to continue.</p>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3 py-2 small"></div>

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control rounded-3" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Email">Email address</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control rounded-3" type="password" autocomplete="current-password" placeholder="Password" />
                            <label asp-for="Password">Password</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                                <label asp-for="RememberMe" class="form-check-label small">Remember me</label>
                            </div>
                            <a href="#" class="small text-decoration-none">Forgot password?</a>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3 fw-semibold py-3">
                                Log in
                            </button>
                        </div>

                        <div class="auth-divider"></div>

                        <p class="text-center text-muted small mb-0">
                            Don&apos;t have an account?
                            <a asp-action="Register" class="fw-semibold text-decoration-none">Create one</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
